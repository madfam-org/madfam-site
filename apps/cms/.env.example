# CMS Configuration
# Placeholder-only. Do not paste live values into this file.
# Production/staging secrets must come from Enclii secrets backed by
# Lockbox/Vault/ESO.
PORT=3091
NODE_ENV=development

# Payload CMS
PAYLOAD_SECRET=replace-with-payload-secret
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# Database (same as web app)
DATABASE_URL=replace-with-local-or-secret-store-database-url

# CORS Origins
PAYLOAD_CORS_ORIGINS=http://localhost:3000,https://madfam.io,https://staging.madfam.io
