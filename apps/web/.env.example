# Database
DATABASE_URL="postgresql://user:password@localhost:5432/madfam_db?schema=public"

# Email Service (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="hello@madfam.io"

# n8n Integration
N8N_WEBHOOK_URL="https://n8n.madfam.io/webhook"
N8N_API_KEY="your-n8n-api-key"

# Feature Flags
NEXT_PUBLIC_ENV="development"
NEXT_PUBLIC_FEATURE_FLAGS_ENABLED="true"

# Sentry Error Tracking
SENTRY_DSN="https://xxxxxxxxxxxx@sentry.io/xxxxxxxxxxxx"
NEXT_PUBLIC_SENTRY_DSN="https://xxxxxxxxxxxx@sentry.io/xxxxxxxxxxxx"

# Cloudflare
CLOUDFLARE_ZONE_ID="xxxxxxxxxxxx"
CLOUDFLARE_API_TOKEN="xxxxxxxxxxxx"

# API Rate Limiting
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# API Authentication
API_SECRET="your-api-secret-key-here"
PORT=3090

# Fortuna Problem Intelligence (MADFAM Integration)
NEXT_PUBLIC_FORTUNA_API_URL="https://api.fortuna.tube"
NEXT_PUBLIC_FORTUNA_API_KEY="your-fortuna-api-key"

# AVALA Learning & Competency (MADFAM Integration)
NEXT_PUBLIC_AVALA_API_URL="https://api.avala.madfam.io"
NEXT_PUBLIC_AVALA_API_KEY="your-avala-api-key"
NEXT_PUBLIC_AVALA_TENANT_ID="madfam"
NEXT_PUBLIC_MADFAM_TEAM_ID="madfam-core"

# Coforma Studio - Customer Advisory Board (MADFAM Integration)
NEXT_PUBLIC_COFORMA_API_URL="https://api.coforma.studio"
NEXT_PUBLIC_COFORMA_API_KEY="your-coforma-api-key"
NEXT_PUBLIC_COFORMA_TENANT_ID="madfam"
NEXT_PUBLIC_COFORMA_PRODUCT_ID="madfam-site"
