# MADFAM web app environment template
# Placeholder-only. Do not paste live values into this file.
# Production/staging secrets must come from Enclii secrets backed by
# Lockbox/Vault/ESO.

# Database
DATABASE_URL="replace-with-local-or-secret-store-database-url"

# Email Service (Resend)
RESEND_API_KEY="replace-with-resend-api-key"
RESEND_FROM_EMAIL="replace-with-sender-email"

# n8n Integration
N8N_WEBHOOK_URL="replace-with-n8n-webhook-url"
N8N_API_KEY="replace-with-n8n-api-key"

# Feature Flags
NEXT_PUBLIC_ENV="development"
NEXT_PUBLIC_FEATURE_FLAGS_ENABLED="true"

# Sentry Error Tracking
SENTRY_DSN="replace-with-sentry-dsn"
NEXT_PUBLIC_SENTRY_DSN="replace-with-public-sentry-dsn"

# Cloudflare
CLOUDFLARE_ZONE_ID="replace-with-cloudflare-zone-id"
CLOUDFLARE_API_TOKEN="replace-with-cloudflare-api-token"

# API Rate Limiting
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# API Authentication
API_SECRET="replace-with-api-secret"
PORT=3090

# Fortuna Problem Intelligence (MADFAM Integration)
NEXT_PUBLIC_FORTUNA_API_URL="https://api.fortuna.tube"
NEXT_PUBLIC_FORTUNA_API_KEY="replace-with-public-fortuna-client-key-if-used"

# AVALA Learning & Competency (MADFAM Integration)
NEXT_PUBLIC_AVALA_API_URL="https://api.avala.madfam.io"
NEXT_PUBLIC_AVALA_API_KEY="replace-with-public-avala-client-key-if-used"
NEXT_PUBLIC_AVALA_TENANT_ID="madfam"
NEXT_PUBLIC_MADFAM_TEAM_ID="madfam-core"

# Coforma Studio - Customer Advisory Board (MADFAM Integration)
NEXT_PUBLIC_COFORMA_API_URL="https://api.coforma.studio"
NEXT_PUBLIC_COFORMA_API_KEY="replace-with-public-coforma-client-key-if-used"
NEXT_PUBLIC_COFORMA_TENANT_ID="madfam"
NEXT_PUBLIC_COFORMA_PRODUCT_ID="madfam-site"
