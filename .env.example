# =============================================================================
# MADFAM-SITE - Environment Configuration
# =============================================================================
# Placeholder-only template. Copy to .env only for local development.
# DO NOT commit .env to version control.
# Production/staging values must come from Enclii secrets backed by
# Lockbox/Vault/ESO, not from copied documentation or chat transcripts.
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# See PORT_REGISTRY.md in solarpunk-foundry for port assignments
# -----------------------------------------------------------------------------
NODE_ENV=development
WEB_PORT=3000
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# JANUA AUTHENTICATION
# -----------------------------------------------------------------------------
JANUA_ENABLED=true
JANUA_API_URL=http://localhost:8000
JANUA_JWKS_URL=http://localhost:8000/.well-known/jwks.json

# -----------------------------------------------------------------------------
# MADFAM ECOSYSTEM CONNECTIONS
# See PORT_REGISTRY.md for port assignments
# -----------------------------------------------------------------------------
FORGESIGHT_API_URL=http://localhost:4040
COTIZA_API_URL=http://localhost:4030

# -----------------------------------------------------------------------------
# CONTENT MANAGEMENT (Optional)
# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------
# ANALYTICS & MONITORING (Optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=

# -----------------------------------------------------------------------------
# EMAIL (Janua centralized Resend integration)
# -----------------------------------------------------------------------------
# Direct Resend (fallback for local development)
RESEND_API_KEY=replace-with-local-resend-api-key
RESEND_FROM_EMAIL=hello@madfam.io

# Janua Email Service (preferred - centralized)
JANUA_INTERNAL_API_KEY=replace-with-janua-internal-api-key

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
ENABLE_BLOG=true
ENABLE_CAREERS=true
ENABLE_CONTACT_FORM=true
